// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// 🏥 CLINIC (Multi-tenancy)
// ============================================
model Clinic {
  id           String   @id @default(cuid())
  name         String
  address      String?
  phone        String?
  email        String?  @unique
  logoUrl      String?
  subscription String   @default("free") // free, pro, enterprise
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  users          User[]
  patients       Patient[]
  staff          Staff[]
  appointments   Appointment[]
  inventoryItems InventoryItem[]
  services       Service[]
  auditLogs      AuditLog[]
}

// ============================================
// 👥 USERS & AUTHENTICATION
// ============================================

model User {
  id            String    @id
  email         String    @unique
  password      String?
  fullName      String
  phone         String?
  role          UserRole  @default(RECEPTIONIST)
  avatar        String?
  isActive      Boolean   @default(true)
  clinicId      String
  clinic        Clinic    @relation(fields: [clinicId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  staff         Staff?
  appointments  Appointment[] @relation("AssignedAppointments")
  treatments    Treatment[]   @relation("AssignedTreatments")
  payments      Payment[]     @relation("ProcessedPayments")
  auditLogs     AuditLog[]
  
  @@map("users")
}

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  ASSISTANT
}

// ============================================
// �‍⚕️ STAFF (HR & Payroll)
// ============================================

model Staff {
  id            String   @id @default(cuid())
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  employeeCode  String   @unique
  fullName      String
  specialty     String?
  certification String?
  phone         String
  email         String
  address       String?
  salary        Decimal? @db.Decimal(10, 2)
  joinDate      DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  appointments  Appointment[] @relation("StaffAppointments")
  treatments    Treatment[]   @relation("StaffTreatments")
  
  @@index([employeeCode])
  @@map("staff")
}

// ============================================
// �� PATIENTS
// ============================================

model Patient {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  fileNumber      String   @unique
  fullName        String
  nationalId      String?
  phone           String
  altPhone        String?
  email           String?
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      String?
  city            String?
  address         String?
  job             String?
  notes           String?
  allergies       String?  @db.Text
  mouthMap        Json?    @default("{}")
  avatar          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  medicalHistory  MedicalHistory[]
  appointments    Appointment[]
  treatments      Treatment[]
  payments        Payment[]
  invoices        Invoice[]
  mediaFiles      MediaFile[]
  
  @@index([phone])
  @@index([fileNumber])
  @@map("patients")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ============================================
// 🩺 MEDICAL HISTORY
// ============================================

model MedicalHistory {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  condition String   // e.g., "Diabetes", "Heart Disease"
  value     String?  // e.g., "Type 2", "High BP"
  severity  Severity @default(LOW)
  notes     String?
  
  createdAt DateTime @default(now())
  
  @@map("medical_histories")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

// ============================================
// 📅 APPOINTMENTS
// ============================================

model Appointment {
  id            String           @id @default(cuid())
  clinicId      String
  clinic        Clinic           @relation(fields: [clinicId], references: [id])
  patientId     String
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?            @relation("AssignedAppointments", fields: [userId], references: [id])
  staffId       String?
  staff         Staff?           @relation("StaffAppointments", fields: [staffId], references: [id])
  date          DateTime
  startTime     String
  endTime       String?
  status        AppointmentStatus @default(SCHEDULED)
  type          String?
  notes         String?
  reason        String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@index([patientId])
  @@index([userId])
  @@index([date])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// 🦷 CLINICAL & TREATMENTS
// ============================================

model Treatment {
  id            String           @id @default(cuid())
  patientId     String
  patient       Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?            @relation("AssignedTreatments", fields: [userId], references: [id])
  staffId       String?
  staff         Staff?           @relation("StaffTreatments", fields: [staffId], references: [id])
  toothNumber   String?
  surface       String?
  procedureType String
  procedureName String
  status        TreatmentStatus  @default(PLANNED)
  priority      Priority         @default(MEDIUM)
  cost          Decimal          @default(0) @db.Decimal(10, 2)
  completedAt   DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  invoiceItems  InvoiceItem[]
  
  @@index([patientId])
  @@index([status])
  @@map("treatments")
}

enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================
// 💸 FINANCE & PAYMENTS
// ============================================

model Payment {
  id            String        @id @default(cuid())
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?         @relation("ProcessedPayments", fields: [userId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(CASH)
  type          PaymentType   @default(PAYMENT)
  notes         String?
  reference     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([patientId])
  @@index([userId])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  BANK_TRANSFER
  INSURANCE
}

enum PaymentType {
  PAYMENT
  REFUND
  ADJUSTMENT
}

// ============================================
// 📄 INVOICES
// ============================================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  totalAmount   Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  items         InvoiceItem[]
  
  @@index([patientId])
  @@index([invoiceNumber])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  treatmentId   String?
  treatment     Treatment? @relation(fields: [treatmentId], references: [id])
  description   String
  quantity      Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
  
  @@index([invoiceId])
  @@map("invoice_items")
}

// ============================================
// 🦷 SERVICES
// ============================================

model Service {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  name          String
  nameAr        String?
  code          String   @unique
  category      String
  price         Decimal  @db.Decimal(10, 2)
  duration      Int?     // minutes
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([category])
  @@map("services")
}

// ============================================
// 📦 INVENTORY
// ============================================

model InventoryItem {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id])
  name          String
  nameAr        String?
  code          String   @unique
  category      String
  quantity      Int      @default(0)
  unit          String
  minStock      Int      @default(10)
  price         Decimal  @default(0) @db.Decimal(10, 2)
  supplier      String?
  expiryDate    DateTime?
  location      String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([code])
  @@index([category])
  @@map("inventory_items")
}

// ============================================
// � MEDIA FILES (Supabase Storage)
// ============================================

model MediaFile {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  fileName  String
  fileUrl   String
  fileType  String   // Image, PDF, X-Ray
  size      Int?
  
  createdAt DateTime @default(now())
  
  @@map("media_files")
}

// ============================================
// 📜 AUDIT LOG
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  
  action     String   // CREATE, UPDATE, DELETE
  entityType String   // Patient, Appointment, etc.
  entityId   String
  diff       Json?    // Store the changes
  
  createdAt  DateTime @default(now())
  
  @@map("audit_logs")
}

// ============================================
// 🔔 NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
